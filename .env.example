# Public domain (used by Caddy for HTTPS). Use localhost for dev.
DOMAIN=localhost

# --- Backend ---
# In production set a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-in-production-please

# CORS / cookie domain. Comma-separated. Use https in prod.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Postgres (used by docker-compose; SQLite is used automatically for pytest).
POSTGRES_USER=checkers
POSTGRES_PASSWORD=checkers
POSTGRES_DB=checkers
DATABASE_URL=postgresql+asyncpg://checkers:checkers@db:5432/checkers

# --- AI Coach (Anthropic Claude) ---
# Optional: if empty, AI Coach falls back to template narratives so the app
# still demos end-to-end without paid keys.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Stripe (test mode) ---
# Get keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs from your Stripe product
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/pricing

# --- Frontend (Vite reads VITE_* at build time) ---
VITE_API_BASE=/api
VITE_WS_BASE=/ws
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
