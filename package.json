{
  "name": "blitz-checkers",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "dev:frontend": "node scripts/sync-public-env.mjs && npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "node scripts/apply-supabase-migrations.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "pg": "^8.20.0"
  }
}
